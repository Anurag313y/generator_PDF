# Used by docker-compose (copy to .env in this folder, or pass -e / --env-file)

# Required in production — use a long random string (e.g. openssl rand -hex 32)
JWT_SECRET=change_this_jwt_secret_in_production

# Host port mapped to the nginx frontend (default 3000 → http://localhost:3000)
APP_PORT=3000

# Admin bootstrap (optional)
# If true, backend will create/update the admin user on startup.
ADMIN_BOOTSTRAP=true
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=admin@123
